<!DOCTYPE html>
<html>
  <head>
    <title>Tacostagram Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <div>
      <%= flash["notice"] %>
    </div>
    <nav class="navbar">
      <a href="/">Home</a>
      <div>
        <% if @current_user %>
          <span>Hello, <%= @current_user.username %>!</span>
          <a href="/logout">Logout</a>
        <% else %>
          <a href="/login">Login</a> | 
          <a href="/users/new">Signup</a>
        <% end %>
      </div>
    </nav>

    <%= yield %>
  </body>
</html>
